# HubSpot Private App Token
# Create at: Settings > Integrations > Private Apps
# Scopes needed: crm.objects.contacts.read
HUBSPOT_TOKEN=pat-na2-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SQLite database path — absolute path on the Pi
# Defaults to ./composer.db if not set
DB_PATH=/home/pi/vbn-composer/composer.db

# Optional: basic auth password to protect the tool
# Leave blank to disable
COMPOSER_PASSWORD=
